{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timbreprint",
  "version": "0.1.0",
  "identifier": "com.kidow.timbreprint",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Timbreprint",
        "width": 1120,
        "height": 780,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.svg"]
  }
}
